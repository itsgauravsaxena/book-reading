default_platform(:ios)

APP_ID = "com.ymga.bibliophil"
WIDGET_ID = "com.ymga.bibliophil.widget"
PROJECT = "Paged.xcodeproj"
SCHEME = "Paged"

platform :ios do
  before_all do
    # Creates a temporary keychain on CI so match can install certs cleanly.
    setup_ci if ENV["CI"]
  end

  desc "Archive and upload a build to TestFlight"
  lane :beta do
    key = asc_api_key
    regenerate_project
    sync_signing(key)
    build(key)
    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Archive and submit a build to App Store review"
  lane :release do
    key = asc_api_key
    regenerate_project
    sync_signing(key)
    build(key)
    upload_to_app_store(
      api_key: key,
      precheck_include_in_app_purchases: false,
      submit_for_review: false,   # flip to true once metadata + screenshots are set in App Store Connect
      automatic_release: false,
      force: true,                # skip the HTML preview prompt
      run_precheck_before_submit: false
    )
  end

  # --- helpers ---

  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],     # base64-encoded contents of the .p8
      is_key_content_base64: true,
      in_house: false
    )
  end

  def regenerate_project
    # The .xcodeproj is generated from project.yml and not committed.
    sh("cd .. && xcodegen generate")
  end

  def sync_signing(key)
    match(
      type: "appstore",
      readonly: ENV["CI"] && ENV["MATCH_READONLY"] != "false",
      api_key: key,
      app_identifier: [APP_ID, WIDGET_ID]
    )
  end

  def build(key)
    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: {
        provisioningProfiles: {
          APP_ID => "match AppStore #{APP_ID}",
          WIDGET_ID => "match AppStore #{WIDGET_ID}"
        }
      }
    )
  end
end
